<?xml version="1.0"?>
<info xmlns:xsi= "http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="https://apps.nextcloud.com/schema/apps/info.xsd">
    <id>s3shadowmigrator</id>
    <name>S3 Shadow Migrator</name>
    <summary>Seamlessly decouple physical file storage to S3</summary>
    <description>
        Silently drains local storage to an S3-compatible object store and intercepts download requests
        with zero-bandwidth 302 Pre-signed URLs, rendering the Nextcloud host entirely stateless.
    </description>
    <version>1.1.0</version>
    <licence>agpl</licence>
    <author>josephang</author>

    <namespace>S3ShadowMigrator</namespace>

    <category>files</category>

    <dependencies>
        <nextcloud min-version="25" max-version="33"/>
    </dependencies>

    <background-jobs>
        <job>OCA\S3ShadowMigrator\BackgroundJob\ShadowMigrationJob</job>
        <job>OCA\S3ShadowMigrator\BackgroundJob\SelfHealingJob</job>
    </background-jobs>

    <repair-steps>
        <post-migration>
            <step>OCA\S3ShadowMigrator\Migration\Version1000000Date20260505000000</step>
        </post-migration>
    </repair-steps>

    <commands>
        <command>OCA\S3ShadowMigrator\Command\MigrateFileCommand</command>
        <command>OCA\S3ShadowMigrator\Command\GcCommand</command>
        <command>OCA\S3ShadowMigrator\Command\RestoreUserCommand</command>
    </commands>

    <settings>
        <admin>OCA\S3ShadowMigrator\Settings\Admin</admin>

    </settings>
</info>
